def _match_magma_offer(question, recommendations):
    q = question.lower()
    numbers = []
    for raw in re.findall(r"\d[\d,]*", q):
        try:
            numbers.append(int(raw.replace(',', '')))
        except ValueError:
            pass

    for rec in recommendations:
        alias = rec.get("node_alias", "")
        if alias and alias.lower() in q:
            return rec

    for rec in recommendations:
        if int(rec.get("size_sat", 0)) in numbers:
            return rec

    return None



def _fuzzy_match_command(user_input):
    """Check if user input is close to a known command pattern. Returns suggestion or None."""
    from difflib import get_close_matches
    
    # Known command patterns (natural language versions)
    known_patterns = [
        "cancel invoice",
        "delete invoice",
        "remove invoice",
        "create invoice",
        "make invoice",
        "generate invoice",
        "invoice for",
        "what is my balance in usd",
        "convert to usd",
        "can i afford",
        "magma offer",
        "should i rebalance",
        "rebalance now",
        "low inbound",
        "low outbound",
    ]
    
    # Get close matches (cutoff=0.6 means 60% similarity required)
    matches = get_close_matches(user_input.lower(), known_patterns, n=3, cutoff=0.6)
    
    if matches:
        return matches[0]  # Return best match
    return None



