def cmd_deposit(args):
    """Receive on-chain Bitcoin — generates QR code and polls for arrival."""
    import time

    amount_sat = getattr(args, "amount", None)

    print(f"\n{W}Receive On-Chain Bitcoin{NC}")
    print(f"{DIM}{'─' * 55}{NC}")

    # Fresh native SegWit address
    addr_data, err = lncli("newaddress", "p2wkh")
    if err or not addr_data:
        print(f"  {R}Failed to generate address: {err}{NC}\n")
        return

    address = addr_data.get("address", "")
    if not address:
        print(f"  {R}No address returned from LND{NC}\n")
        return

    # BIP-21 URI — wallet scans and pre-fills amount if provided
    if amount_sat:
        btc_amount = amount_sat / 1e8
        uri = f"bitcoin:{address}?amount={btc_amount:.8f}"
        print(f"  Amount:  {W}{fmt_sat(amount_sat)}{NC}")
    else:
        uri = f"bitcoin:{address}"

    print(f"  Address: {W}{address}{NC}")

    qr_url = _generate_btc_qr(uri, address, amount_sat)
    if qr_url:
        print(f"\n  {W}Scan to pay (any Bitcoin wallet):{NC}")
        print(f"  {C}{qr_url}{NC}")
    print(f"\n  {DIM}URI: {uri}{NC}")
    print(f"{DIM}{'─' * 55}{NC}")
    print(f"  {DIM}Waiting for payment  (Ctrl+C to skip){NC}\n")

    # Snapshot current balance for delta detection
    baseline_data, _ = lncli("walletbalance")
    baseline_confirmed   = int((baseline_data or {}).get("confirmed_balance", 0))
    baseline_unconfirmed = int((baseline_data or {}).get("unconfirmed_balance", 0))

    received_unconfirmed = False
    try:
        for _ in range(720):  # poll up to 1 hour
            time.sleep(5)
            wb, _ = lncli("walletbalance")
            if not wb:
                continue
            conf   = int(wb.get("confirmed_balance", 0))
            unconf = int(wb.get("unconfirmed_balance", 0))

            if not received_unconfirmed and unconf > baseline_unconfirmed:
                delta = unconf - baseline_unconfirmed
                print(f"  {Y}📡 Detected! +{fmt_sat(delta)} unconfirmed — waiting for block confirmation...{NC}")
                # Find the TXID of the incoming unconfirmed tx and show mempool link
                txns_data, _ = lncli("listchaintxns")
                if txns_data:
                    txns = txns_data.get("transactions", [])
                    # Most recent incoming tx with 0 confirmations
                    for tx in reversed(txns):
                        if int(tx.get("num_confirmations", 1)) == 0 and int(tx.get("amount", 0)) > 0:
                            txid = tx.get("tx_hash", "")
                            if txid:
                                print(f"  {C}🔍 Track on mempool: https://mempool.space/tx/{txid}{NC}")
                            break
                received_unconfirmed = True

            if conf > baseline_confirmed:
                delta = conf - baseline_confirmed
                print(f"  {G}✅ Confirmed! +{fmt_sat(delta)} received on-chain{NC}")
                print(f"  {DIM}New on-chain balance: {fmt_sat(conf)}{NC}")
                print(f"{DIM}{'─' * 55}{NC}\n")
                return
    except KeyboardInterrupt:
        pass

    print(f"\n  {Y}Stopped watching — address is still valid, funds will arrive when the tx confirms.{NC}\n")


