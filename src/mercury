            rate_pct  = f"{ppm/10000:.4f}%"
            print(f"  {W}{alias:<22}{NC} {DIM}{base_sat:>10}  {rate_pct:>8}  {ppm:>6}{NC}")

    print(f"\n  {DIM}To update: fees set <ppm>   e.g. fees set 100{NC}")
    print(f"{DIM}{'─' * 55}{NC}\n")

