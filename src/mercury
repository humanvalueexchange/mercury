            server_cmd = f"cd {web_dir} && nohup python3 -m http.server {server_port} >/dev/null 2>&1 & echo $! > {pid_file}"
            subprocess.run(server_cmd, shell=True)
            time.sleep(0.5)  # Give server time to start
        
        # Get local IP
        try:
            local_ip = os.getenv("MERCURY_HARDLINE_IP", "")
            if not local_ip:
                s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
                s.connect(("8.8.8.8", 80))
                local_ip = s.getsockname()[0]
                s.close()
        except:
            local_ip = "192.168.1.20"
        
        url = f"http://{local_ip}:{server_port}/invoice_{amount}sat.html"
        return url
        
    except Exception as e:
        return f"Error: {str(e)}"


def _agent_get(path):
    """Fetch JSON from mercury-agent, return (data, error)."""
    try:
        req = urllib.request.Request(f"{AGENT_URL}{path}")
        with urllib.request.urlopen(req, timeout=20) as r:
            return json.loads(r.read()), None
    except Exception as e:
        return None, str(e)


def _agent_post(path, payload):
    """POST JSON to mercury-agent, return (data, error)."""
    try:
        body = json.dumps(payload).encode()
        req = urllib.request.Request(
            f"{AGENT_URL}{path}", data=body,
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        with urllib.request.urlopen(req, timeout=30) as r:
            return json.loads(r.read()), None
    except urllib.error.HTTPError as e:
        try:
            detail = json.loads(e.read()).get("detail", str(e))
        except Exception:
            detail = str(e)
        return None, detail
    except Exception as e:
        return None, str(e)


