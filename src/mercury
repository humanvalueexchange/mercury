def cmd_alerts(args):
    severity_rank = {"critical": 0, "warning": 1, "info": 2}
    severity_icon = {
        "critical": f"{R}✗{NC}",
        "warning": f"{Y}⚠{NC}",
        "info": f"{C}•{NC}",
    }
    severity_color = {
        "critical": R,
        "warning": Y,
        "info": C,
    }

    alerts = []
    events = []

    def add_alert(severity, title, detail):
        alerts.append((severity, title, detail))

    services = [
        ("bitcoind", "Bitcoin Core"),
        ("lnd", "LND"),
        ("btcpayserver", "BTCPay Server"),
        ("nbxplorer", "NBXplorer"),
        ("nginx", "Nginx"),
        ("mercury-agent", "Mercury Agent"),
        ("mercury-llm", "Mercury LLM"),
    ]
    for svc, label in services:
        if not systemctl_is_active(svc):
            add_alert("critical", label, "service is not active")

    info, err = lncli("getinfo")
    if not info:
        add_alert("critical", "LND", err or "node telemetry unavailable")
    else:
        if not info.get("synced_to_chain", False):
            add_alert("critical", "Chain sync", f"block {info.get('block_height', 0)} not yet synced")
        if not info.get("synced_to_graph", False):
            add_alert("warning", "Graph sync", "gossip graph still syncing")
        peers = int(info.get("num_peers", 0))
        if peers < 2:
            add_alert("warning", "Lightning peers", f"only {peers} connected")
        active_channels = int(info.get("num_active_channels", 0))
        pending_channels = int(info.get("num_pending_channels", 0))
        if active_channels == 0:
            add_alert("warning", "Lightning channels", "no active channels")
        if pending_channels > 0:
            events.append(("pending", f"{pending_channels} channel(s) pending confirmation"))

    chans, _ = lncli("listchannels")
    if chans and chans.get("channels"):
        total_local = sum(int(c["local_balance"]) for c in chans["channels"])
        total_remote = sum(int(c["remote_balance"]) for c in chans["channels"])
        total_cap = sum(int(c["capacity"]) for c in chans["channels"])
        local_pct = round(total_local / total_cap * 100) if total_cap else 0
        if local_pct > 90:
            add_alert("warning", "Inbound liquidity", f"{local_pct}% local / {100 - local_pct}% remote — mostly send-only")
        elif local_pct < 10:
            add_alert("warning", "Outbound liquidity", f"{local_pct}% local / {100 - local_pct}% remote — mostly receive-only")
        inactive = [c for c in chans["channels"] if not c.get("active")]
        if inactive:
            add_alert("warning", "Inactive channels", f"{len(inactive)} inactive channel(s)")
    else:
        add_alert("warning", "Channels", "no active channel data available")

    btc_net, _ = bitcoin_cli("getnetworkinfo")
    if btc_net:
        conns = int(btc_net.get("connections", 0))
        if conns < 4:
            add_alert("warning", "Bitcoin peers", f"only {conns} peer connections")

    backup = backup_status()
    if backup.get("warn"):
        add_alert("warning", "Channel backup", backup.get("detail", "backup status unavailable"))

    ssh_disabled = ssh_password_auth_disabled()
    if ssh_disabled is False:
        add_alert("warning", "SSH password auth", "enabled — switch to key-only auth")

    try:
        with open("/etc/ufw/ufw.conf") as _f:
            active = any(l.strip() == "ENABLED=yes" for l in _f)
        if not active:
            add_alert("warning", "UFW Firewall", "inactive — consider enabling")
    except Exception:
        add_alert("warning", "UFW Firewall", "ufw not found")

    try:
        r = subprocess.run(["systemctl", "is-active", "fail2ban"], capture_output=True, text=True, timeout=5)
        if r.stdout.strip() != "active":
            add_alert("warning", "Fail2ban", "inactive")
    except Exception:
        add_alert("warning", "Fail2ban", "not found")

    invoices, _ = lncli("listinvoices", "--max_invoices=5")
    if invoices:
        for inv in invoices.get("invoices", [])[:5]:
            state = inv.get("state", "UNKNOWN")
            amt = int(inv.get("value", 0))
            memo = inv.get("memo", "") or "no memo"
            if state == "SETTLED":
                events.append(("settled", f"Received {fmt_sat(amt)} — {memo}"))
            elif state == "OPEN":
                events.append(("open", f"Open invoice {fmt_sat(amt)} — {memo}"))

    alerts.sort(key=lambda item: (severity_rank[item[0]], item[1]))

    print(f"\n{W}Mercury Alerts{NC}")
    print(f"{DIM}{'─' * 55}{NC}")

    if alerts:
        print(f"  {W}Active alerts{NC}\n")
        for severity, title, detail in alerts:
            icon = severity_icon[severity]
            color = severity_color[severity]
            print(f"  {icon} {color}{title}{NC}")
            print(f"     {detail}")
    else:
        print(f"  {G}No active alerts.{NC}")

    print(f"\n  {W}Recent events{NC}\n")
    if events:
        for _, detail in events[:5]:
            print(f"  {C}•{NC} {detail}")
    else:
        print(f"  {DIM}No recent events.{NC}")

    print(f"\n{DIM}{'─' * 55}{NC}\n")

    if getattr(args, 'ai', False):
        if not alerts:
            ctx = "Mercury node is fully healthy. No active alerts. All systems running normally."
        else:
            critical_count = sum(1 for s, _, _ in alerts if s == "critical")
            warning_count  = sum(1 for s, _, _ in alerts if s == "warning")
            ctx = (f"{len(alerts)} active alert(s): {critical_count} critical, "
                   f"{warning_count} warning(s).\n")
            for severity, title, detail in alerts:
                ctx += f"  [{severity.upper()}] {title}: {detail}\n"
        _ai_insight(ctx, "alerts")


def cmd_health(args):
    """Full node diagnostic — hardware, stack, Lightning, AI, self-tests."""
    import shutil

    OK  = f"{G}✓{NC}"
    ERR = f"{R}✗{NC}"
    WRN = f"{Y}⚠{NC}"

    results = []  # (ok, warn)

    def chk(label, ok, detail="", warn=False):
        sym = WRN if warn else (OK if ok else ERR)
        results.append((ok, warn))
        pad = 28
        print(f"  {sym} {label:<{pad}} {DIM}{detail}{NC}")
        return ok

    def row(label, sym, detail):
        ok = sym == OK
        warn = sym == WRN
        chk(label, ok, detail, warn=warn)

    def sec(title):
        print(f"\n{W}{title}{NC}")
        print(f"{DIM}{'─' * 55}{NC}")

    print(f"\n{C}⚡ Mercury Node — Full Health Check{NC}  {DIM}v{MERCURY_VERSION}{NC}")
    print(f"{DIM}{'─' * 55}{NC}")
    print(f"  {DIM}Running diagnostics...{NC}")

    # ── 1. HARDWARE ──────────────────────────────────────────────────────────
    sec("1 · Hardware")

    # CPU / arch
    try:
        arch = subprocess.check_output(["uname", "-m"], text=True).strip()
        cpus = subprocess.check_output(["nproc"], text=True).strip()
        row("CPU", OK, f"{arch}  {cpus} cores")
    except Exception:
        row("CPU", ERR, "unavailable")

    # RAM
    try:
        with open("/proc/meminfo") as f:
            lines = {l.split(":")[0]: l.split(":")[1].strip() for l in f if ":" in l}
        total_kb = int(lines["MemTotal"].split()[0])
        avail_kb = int(lines["MemAvailable"].split()[0])
        total_gb = round(total_kb / 1024 / 1024, 1)
        used_gb  = round((total_kb - avail_kb) / 1024 / 1024, 1)
        pct      = round(used_gb / total_gb * 100)
        warn_ram = pct > 85
        sym = WRN if warn_ram else OK
        row("RAM", sym, f"{used_gb} GB / {total_gb} GB used ({pct}%)")
    except Exception:
        row("RAM", ERR, "unavailable")

    # Disk
    try:
        disk = shutil.disk_usage("/")
        used_gb = round(disk.used / 1024**3, 1)
        total_gb = round(disk.total / 1024**3, 1)
        pct = round(disk.used / disk.total * 100)
        warn_disk = pct > 85
        sym = WRN if warn_disk else OK
        row("Disk /", sym, f"{used_gb} GB / {total_gb} GB used ({pct}%)")
    except Exception:
        row("Disk /", ERR, "unavailable")

    # CPU temperature
    try:
        temp_raw = subprocess.check_output(
            ["vcgencmd", "measure_temp"], text=True, stderr=subprocess.DEVNULL).strip()
        temp_c = float(temp_raw.replace("temp=", "").replace("'C", ""))
        warn_temp = temp_c > 70
        sym = WRN if warn_temp else OK
        row("CPU Temp", sym, f"{temp_c}°C")
    except Exception:
        try:
            with open("/sys/class/thermal/thermal_zone0/temp") as f:
                temp_c = int(f.read().strip()) / 1000
            warn_temp = temp_c > 70
            sym = WRN if warn_temp else OK
            row("CPU Temp", sym, f"{temp_c}°C")
        except Exception:
            row("CPU Temp", WRN, "unavailable")

    # Hailo AI accelerator
    try:
        hcli = subprocess.run(
            ["hailortcli", "fw-control", "identify"],
            capture_output=True, text=True, timeout=5
        )
        if hcli.returncode == 0:
