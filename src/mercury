def cmd_send(args):
    """Send on-chain Bitcoin."""
    address = args.address
    amount_sat = args.amount
    
    print(f"\n{W}On-Chain Bitcoin Payment{NC}")
    print(f"{DIM}{'─' * 55}{NC}")
    print(f"  Address: {DIM}{address[:40]}...{NC}")
    print(f"  Amount:  {W}{fmt_sat(amount_sat)}{NC}")
    
    # Estimate fee
    print(f"\n  {DIM}Estimating transaction fee...{NC}")
    wallet, _ = lncli("walletbalance")
    confirmed = int((wallet or {}).get("confirmed_balance", 0))
    
    # Use medium priority (10 sat/vbyte)
    fee_rate = 10
    est_fee_sat = fee_rate * 141  # Typical P2WPKH tx size
    total_cost = amount_sat + est_fee_sat
    
    print(f"  Est. Fee: ~{fmt_sat(est_fee_sat)} ({fee_rate} sat/vB)")
    print(f"  Total:    ~{fmt_sat(total_cost)}")
    print(f"  Balance:  {fmt_sat(confirmed)}")
    
    if confirmed < total_cost:
        print(f"\n  {R}❌ Insufficient funds!{NC}")
        print(f"  Need: {fmt_sat(total_cost - confirmed)} more\n")
        return
    
    print(f"  Remaining: ~{fmt_sat(confirmed - total_cost)}")
    
    print(f"\n  {Y}⚠  Send {fmt_sat(amount_sat)} on-chain? [y/N]{NC} ", end="", flush=True)
    try:
        answer = input()
    except (EOFError, KeyboardInterrupt):
        print(f"\n  {Y}Cancelled.{NC}\n")
        return
    if answer.strip().lower() != "y":
        print(f"  {Y}Cancelled.{NC}\n")
        return
    
    print(f"  {DIM}Broadcasting transaction...{NC}")
    result, err = lncli("sendcoins", f"--addr={address}", f"--amt={amount_sat}", f"--sat_per_vbyte={fee_rate}", timeout=30)
    
    if err:
        print(f"  {R}❌ Transaction failed: {err}{NC}\n")
        return
    
    txid = result.get("txid", "")
    print(f"  {G}✅ Transaction broadcast!{NC}")
    print(f"  TXID: {C}{txid}{NC}")
    print(f"\n  {DIM}Waiting for confirmation (10-60 min typical){NC}")
    print(f"{DIM}{'─' * 55}{NC}\n")


