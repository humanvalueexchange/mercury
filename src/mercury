def cmd_channels(args):
    channels, err = lncli("listchannels")
    pending, _ = lncli("pendingchannels")
    
    # Get forwarding history for fee calculations (last 30 days)
    fwd_data, _ = lncli("fwdinghistory", "--start_time=-30d", "--max_events=10000")
    fee_by_chan = {}
    if fwd_data:
        for event in fwd_data.get("forwarding_events", []):
            chan_in = event.get("chan_id_in")
            chan_out = event.get("chan_id_out")
            fee = int(event.get("fee_msat", 0)) / 1000  # convert to sats
            fee_by_chan[chan_in] = fee_by_chan.get(chan_in, 0) + fee
            fee_by_chan[chan_out] = fee_by_chan.get(chan_out, 0) + fee

    print(f"\n{W}Lightning Channels{NC}")
    print(f"{DIM}{'─' * 70}{NC}")

    if channels:
        ch_list = channels.get("channels", [])
        if not ch_list:
            print(f"  {Y}No active channels.{NC}")
        else:
            for c in ch_list:
                local = int(c["local_balance"])
                capacity = int(c["capacity"])
                remote = int(c["remote_balance"])
                pct, color = fmt_pct(local, capacity)
                active = c.get("active", False)
                chan_id = c.get("chan_id", "")
                
                # Get peer alias
                peer = c.get("remote_pubkey", "")[:20] + "..."
                alias_info, _ = lncli("getnodeinfo", f"--pub_key={c['remote_pubkey']}")
                alias = alias_info.get("node", {}).get("alias", peer) if alias_info else peer

                # Calculate age
                lifetime_sec = int(c.get("lifetime", 0))
                if lifetime_sec < 86400:  # < 1 day
                    age_str = f"{lifetime_sec // 3600}h"
                elif lifetime_sec < 86400 * 30:  # < 30 days
                    age_str = f"{lifetime_sec // 86400}d"
                else:  # months
                    age_str = f"{lifetime_sec // (86400 * 30)}mo"
                
                # Get fees earned
                fees_earned = fee_by_chan.get(chan_id, 0)
                fees_str = fmt_sat(int(fees_earned)) if fees_earned > 0 else f"{DIM}0 SAT{NC}"
                
                # Calculate health score (0-100)
                # Factors: balance distribution (40pts), activity (30pts), uptime (30pts)
                balance_score = 40 - abs(50 - pct) * 0.8  # best at 50/50
                uptime_pct = (int(c.get("uptime", 0)) / lifetime_sec * 100) if lifetime_sec > 0 else 0
                uptime_score = min(uptime_pct * 0.3, 30)
                num_updates = int(c.get("num_updates", 0))
                activity_score = min(num_updates / 10 * 30, 30)  # max at 10+ updates
                health = int(balance_score + uptime_score + activity_score)
                
                # Health indicator
                if health >= 80:
                    health_icon = f"{G}●{NC}"
                    health_label = f"{G}{health}{NC}"
                elif health >= 60:
                    health_icon = f"{Y}●{NC}"
                    health_label = f"{Y}{health}{NC}"
                else:
                    health_icon = f"{R}●{NC}"
                    health_label = f"{R}{health}{NC}"
                
                dot = f"{G}●{NC}" if active else f"{R}●{NC}"
                b = bar(pct)
                
                print(f"\n  {dot} {W}{alias}{NC}  {DIM}(age: {age_str}, health: {health_label}/100){NC}")
                print(f"     {color}{b}{NC} {pct:.0f}%")
                print(f"     Local {color}{fmt_sat(local)}{NC}  Remote {DIM}{fmt_sat(remote)}{NC}  Cap {DIM}{fmt_sat(capacity)}{NC}")
                print(f"     Fees earned (30d): {fees_str}  Updates: {DIM}{num_updates}{NC}")
                
