def _grok_share_fetch(url):
    """
    Extract text from a Grok share URL.
    Strategy 1: Playwright (full JS render) — requires: playwright install chromium
    Strategy 2: __NEXT_DATA__ JSON parse (lightweight fallback)
    Returns clean text string or None.
    """
    import re as _re, json as _json, html as _html

    # Strategy 1: Playwright full JS render
    try:
        from playwright.sync_api import sync_playwright as _pw
        with _pw() as p:
            browser = p.chromium.launch(headless=True, args=['--no-sandbox', '--disable-gpu'])
            ctx = browser.new_context(
                user_agent='Mozilla/5.0 (X11; Linux aarch64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36'
            )
            page = ctx.new_page()
            # domcontentloaded fires early; evaluate() avoids inner_text visibility timeout
            page.goto(url, wait_until='domcontentloaded', timeout=60000)
            page.wait_for_timeout(5000)
            raw = page.evaluate('document.body.innerText')
            browser.close()
        if raw and len(raw.strip()) > 100:
            lines = raw.strip().splitlines()
            skip = {'Sign in', 'Sign up', 'Log in', 'Log out', 'Home', 'Explore'}
            while lines and lines[0].strip() in skip:
                lines.pop(0)
            text = _html.unescape('\n'.join(lines).strip())
            return text if len(text) > 100 else None
    except ImportError:
        pass
    except Exception:
        pass

    # Strategy 2: __NEXT_DATA__ lightweight fallback
    try:
        req = urllib.request.Request(
            url,
            headers={
                'User-Agent': 'Mozilla/5.0 (X11; Linux aarch64) AppleWebKit/537.36',
                'Accept': 'text/html,application/xhtml+xml,*/*;q=0.8',
            }
        )
        with urllib.request.urlopen(req, timeout=15) as r:
            html_body = r.read().decode('utf-8', errors='replace')
        m = _re.search(r'<script id="__NEXT_DATA__"[^>]*>(.+?)</script>', html_body, _re.DOTALL)
        if m:
            data = _json.loads(m.group(1))
            props = data.get('props', {}).get('pageProps', {})
            msgs = props.get('messages') or props.get('conversation') or []
            if msgs:
                lines = [_html.unescape(msg.get('content', ''))[:3000]
                         for msg in msgs if msg.get('role') == 'assistant' and msg.get('content')]
                if lines:
                    return '\n\n'.join(lines)
    except Exception:
        pass

    return None


