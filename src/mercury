def cmd_rebalance(args):
    """Circular channel rebalance — push local balance from full channel to empty channels."""
    amount = getattr(args, 'amount', None)
    dry_run = getattr(args, 'dry_run', False)

    print(f"\n{W}Channel Rebalance{NC}")
    print(f"{DIM}{'─' * 55}{NC}")

    # Fetch channels
    channels_data, err = lncli("listchannels")
    if err or not channels_data:
        print(f"  {R}Could not fetch channels: {err}{NC}\n")
        return

    channels = channels_data.get("channels", [])
    if not channels:
        print(f"  {Y}No active channels.{NC}\n")
        return

    # Classify channels; also build a map of pubkey→scid for last_hop selection
    sources  = []   # high local % — need to push out
    sinks    = []   # low local % — good to receive into
    all_chs  = []

    for ch in channels:
        cap      = int(ch.get("capacity", 0))
        local    = int(ch.get("local_balance", 0))
        remote   = int(ch.get("remote_balance", 0))
        scid     = ch.get("scid", "")
        lifetime = int(ch.get("lifetime", 0))   # seconds channel has been open
        pct      = round(local / cap * 100, 1) if cap else 0
        reserve  = int(ch.get("local_chan_reserve_sat", 0))
        spendable = max(0, local - reserve - 1000)
        entry = {
            "scid":       scid,
            "scid_str":   ch.get("scid_str", str(scid)),
            "pubkey":     ch.get("remote_pubkey", ""),
            "alias":      ch.get("peer_alias", ""),
            "local":      local,
            "remote":     remote,
            "cap":        cap,
            "pct":        pct,
            "spendable":  spendable,
            "active":     ch.get("active", False),
            "lifetime":   lifetime,
        }
        all_chs.append(entry)
        if pct >= 60:
            sources.append(entry)
        elif pct <= 20:
            sinks.append(entry)

    # Display current state
    print(f"  {'Peer':<16} {'Local':>10} {'Remote':>10} {'Cap':>10}  {'%':>5}  {'Age':>6}")
    print(f"  {DIM}{'─' * 65}{NC}")
    for e in all_chs:
        age_h   = e["lifetime"] // 3600
        pct     = e["pct"]
        color   = G if 40 <= pct <= 70 else (Y if pct > 70 else R)
        alias   = (e["alias"] or e["scid_str"])[:16]
        new_tag = f" {Y}(new){NC}" if e["lifetime"] < 1800 else ""
        print(f"  {DIM}{alias:<16}{NC} {fmt_sat(e['local']):>10} {fmt_sat(e['remote']):>10} "
              f"{fmt_sat(e['cap']):>10}  {color}{pct:>4}%{NC}  {DIM}{age_h:>4}h{NC}{new_tag}")

    print(f"\n  {DIM}Source channels (>60% local):{NC} {len(sources)}")
    print(f"  {DIM}Sink channels   (<20% local):{NC} {len(sinks)}\n")

    if not sources:
        print(f"  {G}✅ Channels are already balanced — no rebalance needed.{NC}\n")
        return
    if not sinks:
        print(f"  {Y}No suitable sink channels (all channels have >20% local).{NC}\n")
        return

    # Pick best source (highest local %) and best sink (most inbound = most remote)
    source = max(sources, key=lambda x: x["pct"])
    sink   = max(sinks,   key=lambda x: x["remote"])

    # Warn if source channel is brand new — gossip may not have propagated
    if source["lifetime"] < 1800:
        age_min = source["lifetime"] // 60
        print(f"  {Y}⚠ Source channel is only {age_min} min old.{NC}")
        print(f"  {DIM}  Channel gossip typically takes 15–30 min to propagate.{NC}")
        print(f"  {DIM}  Rebalance may fail — try again in {30 - age_min} min if it does.{NC}\n")

    max_rebalance = source["spendable"]

    if amount is None:
        # Target 50% balance on source channel
        target_local = int(source["cap"] * 0.50)
        amount = max(0, source["local"] - target_local)
        amount = min(amount, max_rebalance)
        # Cap at 200K SAT per attempt for reliability
        amount = min(amount, 200_000)

    amount = min(amount, max_rebalance)

    if amount < 5_000:
        print(f"  {Y}Rebalance amount too small ({amount} sat) — nothing to do.{NC}\n")
        return

    print(f"  {W}Plan:{NC}")
    print(f"    Source:  {W}{source['alias'] or source['scid_str']}{NC}  ({source['pct']}% local → target ~50%)")
    print(f"    Return:  {W}{sink['alias'] or sink['scid_str']}{NC}  ({sink['pct']}% local, {fmt_sat(sink['remote'])} inbound)")
    print(f"    Amount:  {W}{fmt_sat(amount)}{NC}")
    print(f"    Method:  circular self-payment  |  up to 5 parts  |  last_hop: {sink['alias'] or sink['pubkey'][:16]}\n")

    if dry_run:
        print(f"  {DIM}Dry run — no payment sent.{NC}\n")
        return

    try:
        confirm = input(f"  Type {W}yes{NC} to execute rebalance: ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print(f"\n  {DIM}Cancelled.{NC}\n")
        return

    if confirm != "yes":
        print(f"  {DIM}Aborted.{NC}\n")
        return

    # Progressive retry: try full amount, then halves, down to 50K minimum
    attempts = []
    a = amount
    while a >= 50_000:
        attempts.append(a)
        a = a // 2
    if not attempts:
        attempts = [amount]

    for attempt_amt in attempts:
        print(f"\n  {DIM}Attempt: {fmt_sat(attempt_amt)} sat...{NC}")

        # Create fresh self-invoice for this attempt
        inv_data, inv_err = lncli("addinvoice", f"--amt={attempt_amt}", "--expiry=300",
                                  "--memo=mercury-rebalance")
        if inv_err or not inv_data:
            print(f"  {R}Failed to create invoice: {inv_err}{NC}\n")
            return

        bolt11 = inv_data.get("payment_request", "")
        if not bolt11:
            print(f"  {R}No payment_request in invoice response.{NC}\n")
            return

        # Pay with outgoing channel forced + last_hop hint + MPP allowed
        pay_data, pay_err = lncli(
            "payinvoice", "--force", "--allow_self_payment",
            "--max_parts=5",
            f"--fee_limit_sat={max(50, attempt_amt // 200)}",  # max 0.5% fee
            bolt11,
            f"--outgoing_chan_id={source['scid']}",
            f"--last_hop_pubkey={sink['pubkey']}",
            timeout=120,
        )

        if pay_err:
            print(f"  {Y}↳ No path found for {fmt_sat(attempt_amt)} — trying smaller...{NC}")
            continue

        # Success
        fee_sat = 0
        if pay_data:
            fee_sat = int(pay_data.get("fee_sat", pay_data.get("fee", 0)))

        print(f"\n  {G}✅ Rebalance complete!{NC}")
        print(f"     Moved:   {W}{fmt_sat(attempt_amt)}{NC}")
        if fee_sat:
            print(f"     Fee:     {Y}{fmt_sat(fee_sat)} SAT{NC}  {DIM}({round(fee_sat/attempt_amt*100,3)}%){NC}")
        print(f"     Run {W}channels{NC} to see updated balances.")
        print(f"{DIM}{'─' * 55}{NC}\n")
        if getattr(args, 'ai', False):
            ctx = (f"Rebalance succeeded. Moved {attempt_amt} SAT from {source['alias']} "
                   f"to {sink['alias']}. Fee paid: {fee_sat} SAT "
                   f"({round(fee_sat/attempt_amt*100,3) if attempt_amt else 0}%).")
            _ai_insight(ctx, "rebalance")
        return

    # All attempts failed
    print(f"\n  {R}✗ All routing attempts failed.{NC}")
    lifetime_min = source["lifetime"] // 60
    if lifetime_min < 30:
        print(f"  {Y}Most likely cause: ACINQ channel is only {lifetime_min} min old.{NC}")
        print(f"  {DIM}Wait {30 - lifetime_min} more min for gossip propagation and retry.{NC}")
    else:
        print(f"  {DIM}The network couldn't find a circular path right now.{NC}")
        print(f"  {DIM}Try again later or open another channel for more routing options.{NC}")
    print(f"{DIM}{'─' * 55}{NC}\n")

    if getattr(args, 'ai', False):
        ctx = (f"Rebalance failed. Source: {source['alias']} ({source['pct']}% local, "
               f"{source['local']} SAT). Sink: {sink['alias']} ({sink['remote']} SAT inbound). "
               f"Channel age: {source['lifetime']//60} min.")
        _ai_insight(ctx, "rebalance")


def _build_node_context():
    """Collect live node telemetry for AI context."""
    info, _     = lncli("getinfo")
    wallet, _   = lncli("walletbalance")
    channels, _ = lncli("listchannels")
    pending, _  = lncli("pendingchannels")
    ctx = ""
    if info:
        ctx += f"Node alias: {info.get('alias')}\n"
        ctx += f"Block height: {info.get('block_height')}, synced: {info.get('synced_to_chain')}\n"
        ctx += f"Active channels: {info.get('num_active_channels')}, pending: {info.get('num_pending_channels')}\n"
    if wallet:
        ctx += f"Wallet: {wallet.get('confirmed_balance')} SAT confirmed, {wallet.get('unconfirmed_balance')} SAT pending\n"
    if channels:
        for c in channels.get("channels", []):
            local = int(c["local_balance"])
            cap   = int(c["capacity"])
            remote = int(c.get("remote_balance", 0))
            pct   = round(local/cap*100, 1) if cap else 0
            ctx += f"Channel: local {local} SAT / remote {remote} SAT / capacity {cap} SAT ({pct}% local)\n"
    if pending:
        for p in pending.get("pending_open_channels", []):
            ch = p.get("channel", {})
            ctx += f"Pending channel: {ch.get('local_balance')} SAT / {ch.get('capacity')} SAT (awaiting confirmation)\n"
    return ctx


