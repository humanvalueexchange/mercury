def _ask_dgx(question, system_prompt):
    """Stream answer from DGX Ollama. Returns True on success, False if unreachable."""
    payload = json.dumps({
        "model": OLLAMA_MODEL,
        "prompt": question,
        "system": system_prompt,
        "stream": True,
    }).encode()
    try:
        req = urllib.request.Request(
            f"{OLLAMA_URL}/api/generate",
            data=payload,
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        print(f"  {G}A:{NC} ", end="", flush=True)
        with urllib.request.urlopen(req, timeout=60) as r:
            for line in r:
                chunk = json.loads(line.decode())
                print(chunk.get("response", ""), end="", flush=True)
                if chunk.get("done"):
                    break
        print()
        print()
        return True
    except urllib.error.URLError:
        return False


def _ask_local(question, system_prompt):
    """Stream answer from local Qwen2.5-3B via llama.cpp OpenAI-compatible server."""
    payload = json.dumps({
        "model": LOCAL_LLM_MODEL,
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user",   "content": question},
        ],
        "stream": True,
        "max_tokens": 512,
    }).encode()
    try:
        req = urllib.request.Request(
            f"{LOCAL_LLM_URL}/v1/chat/completions",
            data=payload,
            headers={"Content-Type": "application/json"},
            method="POST",
        )
        print(f"  {G}A:{NC} ", end="", flush=True)
        with urllib.request.urlopen(req, timeout=120) as r:
            for line in r:
                line = line.decode().strip()
                if not line.startswith("data:"):
                    continue
                data = line[5:].strip()
                if data == "[DONE]":
                    break
                try:
                    chunk = json.loads(data)
                    token = chunk.get("choices", [{}])[0].get("delta", {}).get("content", "")
                    print(token, end="", flush=True)
                except (json.JSONDecodeError, IndexError, KeyError):
                    pass
        print()
        print()
        return True
    except urllib.error.URLError as e:
        print()
        print(f"  {R}Local LLM also unreachable: {e}{NC}")
        print(f"  {DIM}Start it with: sudo systemctl start mercury-llm{NC}")
        print()
        return False


