def cmd_channel(args):
    """Open or close a Lightning channel."""
    subcmd = getattr(args, 'channel_action', None)

    if subcmd == "open":
        peer_uri = getattr(args, 'peer', None)
        amount   = getattr(args, 'amount', None)

        print(f"\n{W}Open Lightning Channel{NC}")
        print(f"{DIM}{'─' * 55}{NC}")

        if not peer_uri:
            print(f"  {R}Usage: channel open <node> <amount>{NC}")
            print(f"  {DIM}Example: channel open acinq 500000{NC}")
            print(f"  {DIM}Run `nodes` to see available nodes.{NC}")
            print(f"{DIM}{'─' * 55}{NC}\n")
            return
        if not amount:
            print(f"  {R}Usage: channel open <node> <amount>{NC}")
            print(f"{DIM}{'─' * 55}{NC}\n")
            return

        try:
            sat = int(str(amount).replace("_","").replace(",",""))
        except ValueError:
            print(f"  {R}Invalid amount: {amount}{NC}")
            print(f"{DIM}{'─' * 55}{NC}\n")
            return

        if sat < 20000:
            print(f"  {R}Minimum channel size is 20,000 SAT.{NC}")
            print(f"{DIM}{'─' * 55}{NC}\n")
            return

        # Resolve alias → URI
        resolved_uri, display_name = resolve_node(peer_uri)
        if not resolved_uri:
            print(f"  {R}{display_name}{NC}")
            print(f"{DIM}{'─' * 55}{NC}\n")
            return

        # Warn if below known minimum
        node_info = next((v for v in NODE_DIRECTORY.values() if v["uri"] == resolved_uri), None)
        if node_info and sat < node_info["min_sat"]:
            print(f"  {Y}⚠  {display_name} requires a minimum of {fmt_sat(node_info['min_sat'])}.{NC}")
            print(f"  {Y}   You requested {fmt_sat(sat)} — this will likely be rejected.{NC}\n")

        # Parse pubkey from URI
        pubkey = resolved_uri.split("@")[0]

        # Check on-chain balance
        wallet, werr = lncli("walletbalance")
        onchain = int((wallet or {}).get("confirmed_balance", 0))
        reserved = int((wallet or {}).get("reserved_balance_anchor_chan", 0))
        usable = onchain - reserved
        if sat > usable:
            print(f"  {R}Insufficient on-chain balance.{NC}")
            print(f"  Requested: {fmt_sat(sat)}  |  Usable: {fmt_sat(usable)}  |  Reserved: {fmt_sat(reserved)}")
            print(f"{DIM}{'─' * 55}{NC}\n")
            return

        print(f"  Peer:   {W}{display_name}{NC}")
        print(f"  Amount: {W}{fmt_sat(sat)}{NC}")
        print(f"  On-chain balance after open: ~{fmt_sat(usable - sat)}")
        print(f"\n  {Y}⚠  This will open an on-chain channel (requires ~3 block confirmations).{NC}")

        try:
            confirm = input(f"  Type {W}yes{NC} to proceed: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print(f"\n  {DIM}Cancelled.{NC}")
            print(f"{DIM}{'─' * 55}{NC}\n")
            return
        if confirm != "yes":
            print(f"  {DIM}Aborted.{NC}")
            print(f"{DIM}{'─' * 55}{NC}\n")
            return

        # Connect to peer first
        print(f"\n  {DIM}Connecting to peer...{NC}")
        conn_result, conn_err = lncli("connect", resolved_uri)
        if conn_err and "already connected" not in str(conn_err).lower():
            print(f"  {Y}Connect note: {conn_err}{NC}")

        # Open channel
        print(f"  {DIM}Opening channel...{NC}")
        result, err = lncli("openchannel",
                            f"--node_key={pubkey}",
                            f"--local_amt={sat}",
                            "--min_confs=1")
        if err:
            print(f"  {R}Failed: {err}{NC}")
        else:
            txid = (result or {}).get("funding_txid", "?")
            print(f"  {G}✅ Channel opening broadcast!{NC}")
            print(f"  Funding txid: {W}{txid}{NC}")
            print(f"  {DIM}Track: https://mempool.space/tx/{txid}{NC}")
            print(f"  {DIM}Run `channels` in ~30 min to see it appear as active.{NC}")

    elif subcmd == "close":
        target = getattr(args, 'target', None)

        print(f"\n{W}Close Lightning Channel{NC}")
        print(f"{DIM}{'─' * 55}{NC}")

        if not target:
