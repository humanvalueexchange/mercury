def resolve_node(target):
    """Resolve a node alias or raw pubkey@host:port URI.
    Returns (uri, display_name) or (None, error_msg).
    """
    key = target.strip().lower().replace(" ", "").replace("-", "").replace("_", "")
    # Check directory by normalized key
    for k, info in NODE_DIRECTORY.items():
        if key == k or key == info["alias"].lower().replace(" ", "").replace("-", ""):
            return info["uri"], info["alias"]
    # Fall back to raw URI if it looks like pubkey@host:port
    if "@" in target and ":" in target:
        display = target[:16] + "..." + target.split("@")[1]
        return target, display
    return None, f"Unknown node '{target}'. Run `nodes` to see the directory."


def read_bitcoind_datadir():
    """Best-effort detection of the live Bitcoin Core datadir from systemd."""
    try:
        result = subprocess.run(
            ["systemctl", "show", "-p", "ExecStart", "bitcoind"],
            capture_output=True, text=True, timeout=5
        )
        line = result.stdout.strip()
        match = re.search(r"(?:^|\s)-datadir=(\S+)", line)
        if match:
            return match.group(1)
    except Exception:
        pass

    for candidate in ("/mnt/blockchain/bitcoin", "/var/lib/bitcoin", "/data/bitcoin"):
        if os.path.exists(candidate):
            return candidate
    return None


def bitcoin_cli(*args, timeout=15):
    """Run bitcoin-cli against Mercury's active datadir."""
    datadir = read_bitcoind_datadir()
    cmd = ["bitcoin-cli"]
    if datadir:
        cmd.append(f"-datadir={datadir}")
    cmd += list(args)
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        if result.returncode != 0:
            return None, result.stderr.strip() or result.stdout.strip() or f"exit {result.returncode}"
        return json.loads(result.stdout), None
    except subprocess.TimeoutExpired:
        return None, "timeout"
    except json.JSONDecodeError as e:
        return None, f"json error: {e}"
    except FileNotFoundError:
        return None, "bitcoin-cli not in PATH"
    except Exception as e:
        return None, str(e)


def backup_export_dirs():
    """Locations where exported operator backups may live."""
    return [Path.home() / ".mercury" / "backups", Path("/var/lib/mercury/backups")]


def backup_status():
    """Return best available channel-backup freshness visible to the CLI user."""
    export_files = []
    for export_dir in backup_export_dirs():
        try:
            if export_dir.is_dir():
                export_files.extend(str(p) for p in export_dir.glob("channels-*.bak"))
        except Exception:
            continue

    if export_files:
        export_files = sorted(export_files, key=os.path.getmtime, reverse=True)
        latest = export_files[0]
        age_h = round((time.time() - os.path.getmtime(latest)) / 3600, 1)
        return {
            "warn": age_h > 24,
            "detail": f"{os.path.basename(latest)}  exported {age_h}h ago",
        }

    data, err = lncli("exportchanbackup", "--all")
    if data:
        chan_points = (data.get("multi_chan_backup") or {}).get("chan_points", [])
        count = len(chan_points)
        suffix = "channel" if count == 1 else "channels"
        return {
            "warn": True,
            "detail": f"LND SCB available for {count} {suffix} — run backup to export off-device",
        }

    return {
        "warn": True,
        "detail": f"unable to confirm backup: {err or 'unknown error'}",
    }


def ssh_password_auth_disabled():
    """Best-effort check of sshd password auth using readable config files only."""
    try:
        ssh_files = [Path("/etc/ssh/sshd_config")]
        ssh_files.extend(sorted(Path("/etc/ssh/sshd_config.d").glob("*.conf")))
        password_auth = None
        for ssh_file in ssh_files:
            if not ssh_file.exists():
                continue
            try:
                raw_lines = ssh_file.read_text().splitlines()
            except PermissionError:
                continue
            for raw_line in raw_lines:
                line = raw_line.split("#", 1)[0].strip()
                if not line:
                    continue
                parts = line.split()
                if len(parts) >= 2 and parts[0].lower() == "passwordauthentication":
                    password_auth = parts[1].lower() == "yes"
        return False if password_auth is None else not password_auth
    except Exception:
        return None

# ANSI colors
