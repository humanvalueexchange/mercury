def cmd_suggest(args):
    """Post a research idea as a GitHub Issue to humanvalueexchange/mercury."""
    import json as _json

    # Load token
    env_file = os.path.expanduser('~/.mercury/github.env')
    token = None
    if os.path.exists(env_file):
        for line in open(env_file).read().splitlines():
            if line.startswith('MERCURY_GITHUB_TOKEN='):
                token = line.split('=', 1)[1].strip()
    if not token:
        print(f'  ❌ MERCURY_GITHUB_TOKEN not found in ~/.mercury/github.env')
        return

    title  = getattr(args, 'title', None) or ''
    body   = getattr(args, 'body', None) or ''

    if not title:
        print(f'  ❌ Title required.')
        return

    # Build research template if structured fields provided
    hypothesis = getattr(args, 'hypothesis', None)
    context    = getattr(args, 'context', None)
    direction  = getattr(args, 'direction', None)
    risks      = getattr(args, 'risks', None)

    if hypothesis or context or direction or risks:
        body_parts = []
        if hypothesis: body_parts.append(f'## Hypothesis\n{hypothesis}')
        if context:    body_parts.append(f'## Context\n{context}')
        if direction:  body_parts.append(f'## Proposed Direction\n{direction}')
        if risks:      body_parts.append(f'## Unknowns / Risks\n{risks}')
        body_parts.append(f'\n---\n*Submitted by Mercury (autonomous node agent)*')
        body = '\n\n'.join(body_parts)
    elif not body:
        body = '*Submitted by Mercury (autonomous node agent)*'

    labels = ['research', 'domain:ai']
    payload = _json.dumps({'title': title, 'body': body, 'labels': labels}).encode()

    import urllib.request as _ur
    req = _ur.Request(
        'https://api.github.com/repos/humanvalueexchange/mercury/issues',
        data=payload,
        headers={
            'Authorization': f'Bearer {token}',
            'Accept': 'application/vnd.github+json',
            'Content-Type': 'application/json',
            'X-GitHub-Api-Version': '2022-11-28',
        },
        method='POST'
    )
    try:
        with _ur.urlopen(req, timeout=15) as r:
            data = _json.loads(r.read())
        print(f'  ✅ Issue #{data["number"]} created: {data["html_url"]}')
    except Exception as e:
        print(f'  ❌ Failed to create issue: {e}')

