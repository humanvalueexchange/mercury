        "post":     cmd_post,
        "post-share": cmd_post_share,
        "suggest":    cmd_suggest,
    }

    if args.command is None:
        cmd_shell()
        return

    if args.command in dispatch:
        try:
            dispatch[args.command](args)
        except KeyboardInterrupt:
            print()
