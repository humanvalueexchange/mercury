def cmd_transactions(args):
    """Show recent on-chain Bitcoin transactions with mempool links."""
    import datetime

    limit = getattr(args, 'limit', None) or 10
    show_all = getattr(args, 'all', False)

    txns_data, err = lncli("listchaintxns")
    if err or not txns_data:
        print(f"  {R}Could not fetch transactions: {err}{NC}\n")
        return

    txns = txns_data.get("transactions", [])
    if not txns:
        print(f"  {Y}No on-chain transactions found.{NC}\n")
        return

    # Sort newest first
    txns = sorted(txns, key=lambda x: int(x.get("time_stamp", 0)), reverse=True)
    display = txns if show_all else txns[:limit]

    print(f"\n{W}On-Chain Transactions{NC}  {DIM}({len(txns)} total){NC}")
    print(f"{DIM}{'─' * 55}{NC}")

    for tx in display:
        amount    = int(tx.get("amount", 0))
        confs     = int(tx.get("num_confirmations", 0))
        ts        = int(tx.get("time_stamp", 0))
        tx_hash   = tx.get("tx_hash", "")
        fees      = int(tx.get("total_fees", 0))

        # Date
        try:
            dt = datetime.datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M")
        except Exception:
            dt = "unknown"

        # Direction + colour
        if amount > 0:
            amt_str = f"{G}+{fmt_sat(amount)}{NC}"
            direction = "▲ IN "
        else:
            amt_str = f"{R}{fmt_sat(amount)}{NC}"
            direction = "▼ OUT"

        # Confirmation status
        if confs == 0:
            conf_str = f"{Y}pending{NC}"
        elif confs < 3:
            conf_str = f"{Y}{confs} conf{'s' if confs > 1 else ''}{NC}"
        else:
            conf_str = f"{DIM}{confs} confs{NC}"

        print(f"  {direction}  {amt_str:<28}  {conf_str:<16}  {DIM}{dt}{NC}")
        if fees > 0 and amount < 0:
            print(f"         {DIM}fee: {fmt_sat(fees)}{NC}")
        print(f"         {C}https://mempool.space/tx/{tx_hash}{NC}")

    if not show_all and len(txns) > limit:
        print(f"\n  {DIM}Showing {limit} of {len(txns)}. Run `transactions --all` to see all.{NC}")

    print(f"{DIM}{'─' * 55}{NC}\n")

    if getattr(args, 'ai', False):
        total_in  = sum(int(t.get("amount", 0)) for t in txns if int(t.get("amount", 0)) > 0)
        total_out = sum(abs(int(t.get("amount", 0))) for t in txns if int(t.get("amount", 0)) < 0)
        total_fees_paid = sum(int(t.get("total_fees", 0)) for t in txns if int(t.get("amount", 0)) < 0)
        ctx = (f"On-chain transaction history ({len(txns)} total):\n"
               f"Total received: {total_in} SAT\n"
               f"Total sent: {total_out} SAT\n"
               f"Total fees paid: {total_fees_paid} SAT\n")
        for t in txns[:5]:
            amt  = int(t.get("amount", 0))
            confs = int(t.get("num_confirmations", 0))
            ctx += f"  {'IN' if amt > 0 else 'OUT'}: {abs(amt)} SAT, {confs} confirmations\n"
        _ai_insight(ctx, "transactions")


def cmd_fees(args):
    """Show channel fee policy and earnings. Optionally update fees."""
    subcmd = getattr(args, 'fees_action', None)

    # ── fees set <ppm> [base_msat] ────────────────────────────────────────────
    if subcmd == "set":
        ppm      = getattr(args, 'ppm', None)
        base_msat = getattr(args, 'base_msat', 1000)
        chan_alias = getattr(args, 'channel', None)

        if ppm is None:
            print(f"\n  {R}Usage: fees set <ppm> [base_msat]{NC}")
            print(f"  {DIM}Example: fees set 100          (100 ppm, 1 sat base — all channels){NC}")
            print(f"  {DIM}Example: fees set 50 500       (50 ppm, 0.5 sat base){NC}\n")
            return

        print(f"\n{W}Update Channel Fees{NC}")
        print(f"{DIM}{'─' * 55}{NC}")
        print(f"  Base fee:  {W}{base_msat} msat{NC}  ({base_msat/1000:.3f} SAT per payment)")
        print(f"  Rate:      {W}{ppm} ppm{NC}  ({ppm/10000:.4f}% per routed SAT)")
        print(f"  Scope:     {W}{'all channels' if not chan_alias else chan_alias}{NC}")
        print(f"\n  {Y}⚠  This updates your public routing policy on the Lightning Network.{NC}")

        try:
            confirm = input(f"  Type {W}yes{NC} to proceed: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print(f"\n  {DIM}Cancelled.{NC}\n")
            return
        if confirm != "yes":
            print(f"  {DIM}Aborted.{NC}\n")
            return

        result, err = lncli("updatechanpolicy",
                            f"--base_fee_msat={base_msat}",
                            f"--fee_rate_ppm={ppm}",
                            "--time_lock_delta=40")
        if err:
            print(f"  {R}Failed: {err}{NC}")
