def cmd_shell(args=None):
    """
    Interactive Mercury session.
    Type naturally — anything that isn't a command is sent to Mercury AI.
    Commands: status channels invoices sync peers backup logs pay invoice magma version exit
    """
    import shlex

    COMMANDS = {"status", "channels", "invoices", "sync", "peers",
                "backup", "logs", "pay", "invoice", "charge", "deposit", "magma", "alerts", "health",
                "rebalance", "channel", "nodes", "transactions", "fees", "payments", "routing", "version", "help", "exit", "quit", "clear", "cls", "post-share", "suggest"}

    dispatch = {
        "status":    cmd_status,
        "channels":  cmd_channels,
        "invoices":  cmd_invoice,
        "sync":      cmd_sync,
        "peers":     cmd_peers,
        "backup":    cmd_backup,
        "alerts":    cmd_alerts,
        "logs":      cmd_logs,
        "pay":       cmd_pay,
        "invoice":   cmd_invoice,
        "charge":    cmd_charge,
        "deposit":   cmd_deposit,
        "magma":     cmd_magma,
        "channel":   cmd_channel,
        "nodes":     cmd_nodes,
        "transactions": cmd_transactions,
        "fees":      cmd_fees,
        "payments":  cmd_payments,
        "routing":   cmd_routing,
        "rebalance": cmd_rebalance,
        "health":    cmd_health,
        "version":   cmd_version,
        "post-share": cmd_post_share,
        "suggest":    cmd_suggest,
    }

    # Show brief status on entry
    print(f"\n{C}⚡ Mercury Node  v{MERCURY_VERSION}{NC}  {DIM}— sovereign Bitcoin Lightning node{NC}")
    print(f"{DIM}Type naturally to talk to Mercury AI, or use commands: status channels payments transactions ...{NC}")
    print(f"{DIM}Type 'exit' or press Ctrl+D to quit.{NC}\n")

    # Quick status flash on entry
    try:
        data, err = _agent_get("/api/status")
        if data and not err:
            wallet = data.get("wallet", {})
            chans  = data.get("channels", {})
            bal    = wallet.get("confirmed_sat", 0)
            active = chans.get("active", 0)
            pending = chans.get("pending", 0)
            block  = data.get("node", {}).get("block_height", "?")
            chan_str = f"{active} active" + (f", {pending} pending" if pending else "")
            print(f"  {G}●{NC} {W}{fmt_sat(bal)}{NC}  |  {chan_str}  |  block {block}\n")
    except Exception:
        pass

    while True:
        try:
            line = input(f"{G}⚡{NC} ").strip()
        except (EOFError, KeyboardInterrupt):
            print(f"\n{DIM}Goodbye.{NC}\n")
            break

        if not line:
            continue

        if line.lower() in ("exit", "quit", "bye"):
            print(f"\n{DIM}Goodbye.{NC}\n")
            break

        if line.lower() in ("clear", "cls"):
            os.system("clear")
            continue

        if line.lower() == "help":
            print(f"\n  {W}Commands:{NC}  status  channels  invoices  sync  peers  backup  logs")
            print(f"             pay <bolt11>  invoice <sat> [memo]  rebalance [--amount SAT]")
            print(f"             magma [offers|score|recommend|buy|status|auth]  alerts  health  version  exit")
            print(f"  {W}AI insight:{NC}  add {W}--ai{NC} to any command  e.g. {DIM}status --ai{NC}  {DIM}channels --ai{NC}  {DIM}alerts --ai{NC}")
            print(f"  {W}Or just type naturally{NC} — anything else goes to Mercury AI.\n")
            continue

        try:
            parts = shlex.split(line)
        except ValueError:
            parts = line.split()

        # Allow "mercury <cmd>" prefix inside the shell
        if parts and parts[0].lower() == "mercury" and len(parts) > 1:
            parts = parts[1:]

        cmd = parts[0].lower() if parts else ""
        rest = parts[1:]

        if cmd == "suggest":
            if not rest:
                print(f"  {Y}Usage: suggest \"Title\" [--hypothesis \"...\" --context \"...\" --direction \"...\" --risks \"...\"] [--body \"...\"]{NC}")
                continue
            _sg = argparse.Namespace(
                title=rest[0],
                body=None, hypothesis=None, context=None, direction=None, risks=None
            )
            i = 1
            while i < len(rest):
                for flag in ('--body','--hypothesis','--context','--direction','--risks'):
                    if rest[i] == flag and i + 1 < len(rest):
                        setattr(_sg, flag.lstrip('-'), rest[i+1]); i += 2; break
                else:
                    i += 1
            cmd_suggest(_sg)
            continue

        if cmd == "post-share":
            if not rest:
                print(f"  {Y}Usage: post-share <grok-url> [--channel growth] [--note 'text']{NC}")
                continue
            _ps = argparse.Namespace(url=rest[0], channel='growth', note=None)
            i = 1
            while i < len(rest):
                if rest[i] == '--channel' and i + 1 < len(rest):
                    _ps.channel = rest[i + 1]; i += 2
                elif rest[i] == '--note' and i + 1 < len(rest):
                    _ps.note = rest[i + 1]; i += 2
                else:
                    i += 1
            cmd_post_share(_ps)
            continue

        if cmd not in COMMANDS:
            # Natural language → AI
            ns = argparse.Namespace(question=line.split())
            try:
                cmd_ask(ns)
            except KeyboardInterrupt:
                print()
            continue

        if cmd in ("exit", "quit"):
            print(f"\n{DIM}Goodbye.{NC}\n")
            break

        ns = argparse.Namespace(command=cmd)
        ns.ai = "--ai" in rest   # universal --ai flag for every command
        try:
            if cmd == "invoices":
                ns.recent = "--recent" in rest
                ns.pending = "--pending" in rest
                # Extract --last N if present
                ns.last = 10
                for i, arg in enumerate(rest):
                    if arg == "--last" and i + 1 < len(rest):
                        try:
                            ns.last = int(rest[i + 1])
                        except ValueError:
                            pass
            elif cmd == "logs":
                ns.service = rest[0] if rest else "lnd"
            elif cmd == "pay":
                if not rest:
                    print(f"  {Y}Usage: pay <bolt11>{NC}")
                    continue
                ns.bolt11 = rest[0]
            elif cmd == "invoice":
                if not rest:
                    print(f"  {Y}Usage: invoice <sat> [memo]{NC}")
                    continue
                ns.sat = int(rest[0])
                ns.memo = " ".join(rest[1:]) if len(rest) > 1 else ""
            elif cmd == "charge":
                if not rest:
                    print(f"  {Y}Usage: charge <sat> [memo]{NC}")
                    continue
                ns.sat = int(rest[0])
                ns.memo = " ".join(rest[1:]) if len(rest) > 1 else ""
            elif cmd == "deposit":
                ns.amount = None
                for i, arg in enumerate(rest):
                    if arg == "--amount" and i + 1 < len(rest):
                        try:
                            ns.amount = int(rest[i + 1])
                        except ValueError:
                            pass
                if rest and not rest[0].startswith("-"):
                    try:
                        ns.amount = int(rest[0])
                    except ValueError:
                        pass
            elif cmd == "magma":
                ns.subcmd = rest[0] if rest else "offers"
                ns.min_sat = 100000
                ns.max_sat = 5000000
                ns.node = None
                for i, arg in enumerate(rest):
                    if arg == "--node" and i + 1 < len(rest):
                        ns.node = rest[i + 1]
            elif cmd == "rebalance":
                ns.amount = None
                ns.dry_run = "--dry-run" in rest
                for i, arg in enumerate(rest):
                    if arg == "--amount" and i + 1 < len(rest):
                        try:
                            ns.amount = int(rest[i + 1])
                        except ValueError:
                            pass
            elif cmd == "transactions":
                ns.limit = 10
                ns.all = "--all" in rest
                for i, arg in enumerate(rest):
                    if arg == "--limit" and i + 1 < len(rest):
                        try:
                            ns.limit = int(rest[i + 1])
                        except ValueError:
                            pass
                    elif arg.lstrip("-").isdigit():
                        try:
                            ns.limit = int(arg)
                        except ValueError:
                            pass
            elif cmd == "fees":
                clean_rest = [a for a in rest if a != "--ai"]
                ns.fees_action = clean_rest[0] if clean_rest else None
                rest2 = clean_rest[1:] if len(clean_rest) > 1 else []
                if ns.fees_action == "set":
                    try:
                        ns.ppm      = int(rest2[0]) if rest2 else None
                        ns.base_msat = int(rest2[1]) if len(rest2) > 1 else 1000
                    except (ValueError, IndexError):
                        ns.ppm = None; ns.base_msat = 1000
                    ns.channel = None
                else:
                    ns.ppm = None; ns.base_msat = 1000; ns.channel = None
            elif cmd == "routing":
                try:
                    ns.days = int(rest[0]) if rest else 30
                except ValueError:
                    ns.days = 30
            elif cmd == "payments":
                try:
                    ns.limit = int(rest[0]) if rest else 20
                except ValueError:
                    ns.limit = 20
            elif cmd == "channel":
                ns.channel_action = rest[0] if rest else None
                rest2 = rest[1:] if len(rest) > 1 else []
                if ns.channel_action == "open":
                    ns.peer   = rest2[0] if len(rest2) > 0 else None
                    ns.amount = rest2[1] if len(rest2) > 1 else None
                    ns.target = None
                elif ns.channel_action == "close":
                    ns.target = rest2[0] if len(rest2) > 0 else None
                    ns.peer   = None
                    ns.amount = None
                else:
                    ns.peer = None; ns.amount = None; ns.target = None
        except (ValueError, IndexError) as e:
            print(f"  {R}Argument error: {e}{NC}")
            continue

        try:
            dispatch[cmd](ns)
        except KeyboardInterrupt:
            print()


