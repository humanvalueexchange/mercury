    print(f"    Week:    {G if week_sat > 0 else DIM}{fmt_sat(week_sat)}{NC}")
    print(f"    Month:   {G if month_sat > 0 else DIM}{fmt_sat(month_sat)}{NC}")

    if day_sat == 0 and week_sat == 0 and month_sat == 0:
        print(f"\n  {Y}No routing fees earned yet — set a competitive rate to attract payments.{NC}")
        print(f"  {DIM}Tip: fees set 100   (100 ppm ≈ 0.01% — good starting point){NC}")

    # Per-channel policy
    channel_fees = report.get("channel_fees", [])
    if channel_fees:
        print(f"\n  {W}Policy per channel{NC}")
        print(f"  {DIM}{'Channel':<22} {'Base':>10}  {'Rate':>8}  {'ppm':>6}{NC}")
        print(f"  {DIM}{'─'*22} {'─'*10}  {'─'*8}  {'─'*6}{NC}")
