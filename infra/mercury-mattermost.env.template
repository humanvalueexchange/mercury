# Mercury → Mattermost webhook config template
# Copy to ~/.mercury/mattermost.env and fill in real webhook IDs
# Webhook IDs are created in Mattermost → System Console → Integrations → Incoming Webhooks
# All webhooks use localhost:8065 — Mercury is the Mattermost host
#
# NEVER commit this file with real webhook IDs.

MM_TECH=http://localhost:8065/hooks/<tech-webhook-id>
MM_ALERTS=http://localhost:8065/hooks/<alerts-webhook-id>
MM_TOWN=http://localhost:8065/hooks/<town-webhook-id>
MM_GROWTH=http://localhost:8065/hooks/<growth-webhook-id>
